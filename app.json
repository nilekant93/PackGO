{
  "expo": {
    "name": "PackGO",
    "slug": "PackGO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bags/suitcase.png",
    "scheme": "packgo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.anonymous.packgo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/bags/suitcase.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/bags/tubebag.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/create-trip-hero-guy.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "221121cb-5402-4e94-bc86-8f221b9816e2"
      }
    }
  }
}